{
  "manifest_version": 3,
  "name": "TabMind",
  "version": "1.0",
  "description": "Provides Semantic search over your Chrome history",
  "permissions": [
    "history",
    "storage",
    "activeTab",
    "scripting"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "ui/index.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/index.js"]
    }
  ]
}